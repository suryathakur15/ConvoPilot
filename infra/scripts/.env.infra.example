# ─────────────────────────────────────────────────────────────────────────────
# .env.infra — Local secrets for infra/scripts/create-stack.sh
#
# Copy this file: cp infra/scripts/.env.infra.example infra/scripts/.env.infra
# Fill in your values, then source before deploying:
#   source infra/scripts/.env.infra && ./infra/scripts/create-stack.sh
#
# This file is gitignored — NEVER commit the real .env.infra
# ─────────────────────────────────────────────────────────────────────────────

# ── Database & Redis ──────────────────────────────────────────────────────────
export CONVOPILOT_DB_PASSWORD="your-strong-db-password-min-12-chars"
export CONVOPILOT_REDIS_PASSWORD="your-strong-redis-password-min-12-chars"

# ── AI Provider — set the one you use, leave others blank ────────────────────
export CONVOPILOT_AI_PROVIDER="gemini"   # gemini | claude | openai
export CONVOPILOT_AI_MODEL="gemini-2.5-flash-lite"

export CONVOPILOT_GEMINI_API_KEY=""
export CONVOPILOT_GEMINI_MODEL="gemini-2.5-flash-lite"

export CONVOPILOT_OPENAI_API_KEY=""
export CONVOPILOT_OPENAI_MODEL="gpt-4o"

export CONVOPILOT_ANTHROPIC_API_KEY=""
export CONVOPILOT_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
