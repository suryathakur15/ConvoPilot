# ─── App ───────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=5173
AI_SERVICE_PORT=8000

# ─── PostgreSQL ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=convopilot
POSTGRES_PASSWORD=convopilot_secret
POSTGRES_DB=convopilot
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── AI Service ────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_PROVIDER=claude                  # openai | claude | gemini
AI_MAX_CONTEXT_MESSAGES=20

# ─── AI Provider Keys (fill the one matching AI_PROVIDER) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022   # fast + affordable; alt: claude-opus-4-5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Frontend (Vite) ───────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
VITE_AI_ENABLED=true
